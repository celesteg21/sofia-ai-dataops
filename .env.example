# Variables de entorno de ejemplo para desarrollo local.
# Copiar a `.env` y completar secretos reales, como OPENAI_API_KEY.

APP_NAME="Sofia AI DataOps"
APP_ENV=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sofia
POSTGRES_USER=sofia
POSTGRES_PASSWORD=sofia

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=airflow_incidents
# Usar 1536 cuando OPENAI_API_KEY esta configurada (text-embedding-3-small).
# Usar 64 para modo local sin API key (embeddings deterministicos de fallback).
# IMPORTANTE: si cambias el vector size en una coleccion existente, debes eliminar
# la coleccion en Qdrant antes de reiniciar (o ejecutar make docker-reindex-qdrant).
QDRANT_VECTOR_SIZE=1536

OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=3
EMBEDDING_MODEL=text-embedding-3-small
