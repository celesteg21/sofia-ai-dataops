APP_NAME="Sofia AI DataOps"
APP_ENV=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

# LLM backend: "mock" needs no running model, "ollama" calls a local Ollama instance.
LLM_BACKEND=mock
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# Path to mock environment data (relative to working directory).
MOCK_ENV_PATH=app/mock_environment
