# Variables de entorno de ejemplo para desarrollo local.
# Copiar a `.env` y completar secretos reales, como OPENAI_API_KEY.

APP_NAME="Sofia AI DataOps"
APP_ENV=local
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sofia
POSTGRES_USER=sofia
POSTGRES_PASSWORD=sofia

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=airflow_incidents
QDRANT_VECTOR_SIZE=64

OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
